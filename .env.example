# Enable Banking (PSD2 / Open Banking) — poverilnice za neposredno povezavo na banko.
# Brezplačno tudi za posameznike (Restricted Mode — povežeš svoje lastne račune, brez podjetja).
#
# Postopek:
#   1. Prijava na https://enablebanking.com/sign-in/ (račun se ustvari ob prvi prijavi z e-pošto).
#   2. Control Panel → Applications → registriraj aplikacijo (okolje Production, Restricted Mode).
#   3. Ob registraciji dobiš Application ID in prenese se zasebni ključ (.pem).
#   4. Skopiraj to datoteko v ".env", vpiši Application ID in pot do .pem datoteke.
#   5. V aplikaciji (Control Panel) kot Redirect URL dodaj: http://127.0.0.1:8000/connect/callback

ENABLE_BANKING_APP_ID=
# Pot do zasebnega ključa; privzeto "enablebanking_private.pem" v korenu projekta.
# ENABLE_BANKING_KEY_PATH=enablebanking_private.pem

# Neobvezno:
# ENABLE_BANKING_COUNTRY=SI
# ENABLE_BANKING_BASE_URL=https://api.enablebanking.com
