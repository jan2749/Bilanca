# GoCardless Bank Account Data (PSD2 / Open Banking) — poverilnice za neposredno povezavo na banko.
# Pridobiš jih brezplačno: https://bankaccountdata.gocardless.com → Developers → User secrets → Create new.
# Skopiraj to datoteko v ".env" (brez .example) in vpiši svoja ključa. ".env" NI v gitu.

GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# Neobvezno: privzeti naslov API-ja (spreminjaj le, če veš, kaj počneš).
# GOCARDLESS_BASE_URL=https://bankaccountdata.gocardless.com
